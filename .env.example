# Example environment variables — DO NOT commit real secrets here.
# Copy this file to .env and fill in real values locally.

# Generic API key
API_KEY=your_api_key_here

# Service-specific keys (placeholders)
BAILIAN_API_KEY=your_bailian_api_key_here
OCR_API_KEY=your_ocr_api_key_here

# Database / other secrets
DATABASE_URL=jdbc:h2:mem:testdb
JWT_SECRET=change_me

# Frontend example (Vite) - prefix with VITE_ for client exposure if used
VITE_API_BASE_URL=http://localhost:8080/api
