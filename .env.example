# ========================================
# MedLabAgent example environment file
# Copy this file to `.env` and fill in real secrets locally.
# ========================================

# ========================================
# LLM / Vision APIs
# ========================================
LLM_API_KEY=your_openai_compatible_api_key
LLM_BASE_URL=https://your-openai-compatible-host/v1/chat/completions
LLM_MODEL=gpt-5
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.2
DASHSCOPE_API_KEY=your_dashscope_api_key
VISION_MODEL=qwen-vl-plus
DASHSCOPE_MODEL=qwen3.5-plus-2026-02-15
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ========================================
# Database
# ========================================
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/medlab_db
SPRING_DATASOURCE_USERNAME=medlab_user
SPRING_DATASOURCE_PASSWORD=medlab_password
DATABASE_URL=postgresql://medlab_user:medlab_password@db:5432/medlab_db

# ========================================
# Auth
# ========================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRATION=86400000

# ========================================
# Service URLs
# ========================================
JAVA_BACKEND_URL=http://java-backend:8080
LANGCHAIN_SERVICE_URL=http://python-langchain:8000
OCR_SERVICE_URL=http://python-ocr:8001
SERVER_URL=http://localhost:8080
OCR_ACCESS_URL=http://host.docker.internal:8080

# ========================================
# Upload / Storage
# ========================================
UPLOAD_DIR=./uploads
MEDLAB_UPLOAD_DIR=d:/Users/yourname/path/to/MedLabAgent/uploads

# ========================================
# Redis
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
OCR_CACHE_TTL_SECONDS=3600

# ========================================
# Timeouts / Logging
# ========================================
HTTP_TIMEOUT=30
LLM_API_TIMEOUT=60
JAVA_LOG_LEVEL=INFO
PYTHON_LOG_LEVEL=INFO

# ========================================
# LangSmith (optional)
# ========================================
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=medlab-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ========================================
# MinIO (optional)
# ========================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medlab-reports

# ========================================
# Optional feature flags
# ========================================
MEDLAB_DESENSITIZE_ENABLED=true

# ========================================
# Docker image overrides (optional)
# ========================================
POSTGRES_IMAGE=docker.m.daocloud.io/postgres:15-alpine
REDIS_IMAGE=docker.m.daocloud.io/redis:7-alpine
PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.11-bookworm
